{
  "functions": {
    "src/app/api/analyze/route.ts": {
      "maxDuration": 300,
      "memory": 3008
    }
  },
  "crons": [
    {
      "path": "/api/cron/calculate-trends",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/scrape-trending",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/sync-whop",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/refresh-competitors",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/validate-rules",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/retrain-ml",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/refresh-corpus",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/delete-retained-videos",
      "schedule": "0 3 * * *"
    }
  ]
}
