# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
package-lock.json

# testing
/coverage
/e2e/auth/
/e2e/test-results/
/e2e/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# benchmark runtime data
scripts/benchmark-results.json

# test video fixtures (large binary files)
src/lib/engine/__tests__/fixtures/
scripts/data/

# GSD corpus scrape cache (operator-local, not versioned)
.planning/cache/

# Corpus video downloads — large binaries, regeneratable from training_corpus
.planning/videos-cache/

# Phase 6 audio smoke-test fixtures + results (developer-local, not versioned)
tests/fixtures/audio-smoke/*.mp4
tests/fixtures/audio-smoke/smoke-test-results.json

# Claude Code local state (worktrees, settings.local.json)
.claude/
.claire/

# Playwright MCP debug captures (console logs, snapshots, screenshots)
.playwright-mcp/
# Local design-iteration + verification screenshots dropped at repo root
# (root-scoped — public/ and .planning/sketches/ images are still tracked)
/*.png
/*.jpeg

# Apollo corpus pipeline — operator-local artifacts (regeneratable from URLs)
.planning/corpus/audio-cache/
.planning/corpus/models/
.planning/corpus/raw/
.scratch/

# Dev-only sample media for /dev/cards (never committed — see the Room section)
/public/dev/
