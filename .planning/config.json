{
  "model_profile": "quality",
  "model_overrides": {
    "gsd-advisor-researcher": "opus",
    "gsd-ai-researcher": "opus",
    "gsd-assumptions-analyzer": "opus",
    "gsd-code-fixer": "opus",
    "gsd-code-reviewer": "opus",
    "gsd-codebase-mapper": "opus",
    "gsd-debug-session-manager": "opus",
    "gsd-debugger": "opus",
    "gsd-doc-classifier": "opus",
    "gsd-doc-synthesizer": "opus",
    "gsd-doc-verifier": "opus",
    "gsd-doc-writer": "opus",
    "gsd-domain-researcher": "opus",
    "gsd-eval-auditor": "opus",
    "gsd-eval-planner": "opus",
    "gsd-executor": "opus",
    "gsd-framework-selector": "opus",
    "gsd-integration-checker": "opus",
    "gsd-intel-updater": "opus",
    "gsd-nyquist-auditor": "opus",
    "gsd-pattern-mapper": "opus",
    "gsd-phase-researcher": "opus",
    "gsd-plan-checker": "opus",
    "gsd-planner": "opus",
    "gsd-project-researcher": "opus",
    "gsd-research-synthesizer": "opus",
    "gsd-roadmapper": "opus",
    "gsd-security-auditor": "opus",
    "gsd-team-worker": "opus",
    "gsd-ui-auditor": "opus",
    "gsd-ui-checker": "opus",
    "gsd-ui-researcher": "opus",
    "gsd-user-profiler": "opus",
    "gsd-verifier": "opus"
  },
  "mode": "interactive",
  "parallelization": true,
  "gitTracking": true,
  "agents": {
    "research": true,
    "planCheck": true,
    "verifier": true
  },
  "preferences": {
    "autoCommit": true,
    "testAfterChanges": true,
    "formatOnSave": true
  },
  "project": {
    "name": "virtuna-v1.1",
    "type": "greenfield",
    "framework": "nextjs",
    "version": "1.1.0"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": false,
    "node_repair": true,
    "node_repair_budget": 2,
    "ui_phase": true,
    "ui_safety_gate": true,
    "ai_integration_phase": true,
    "use_worktrees": true,
    "text_mode": false,
    "research_before_questions": true,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "code_review": true,
    "code_review_depth": "standard",
    "_auto_chain_active": false
  },
  "granularity": "fine",
  "git": {
    "branching_strategy": "none",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": null
  },
  "hooks": {
    "context_warnings": true
  }
}
