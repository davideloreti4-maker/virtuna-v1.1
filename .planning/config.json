{
  "model_profile": "balanced",
  "mode": "interactive",
  "parallelization": true,
  "gitTracking": true,
  "agents": {
    "research": true,
    "planCheck": true,
    "verifier": true
  },
  "preferences": {
    "autoCommit": true,
    "testAfterChanges": true,
    "formatOnSave": true
  },
  "project": {
    "name": "virtuna-v1.1",
    "type": "greenfield",
    "framework": "nextjs",
    "version": "1.1.0"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": false,
    "node_repair": true,
    "node_repair_budget": 2,
    "ui_phase": true,
    "ui_safety_gate": true,
    "ai_integration_phase": true,
    "use_worktrees": true,
    "text_mode": false,
    "research_before_questions": true,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "code_review": true,
    "code_review_depth": "standard",
    "_auto_chain_active": false
  },
  "granularity": "fine",
  "git": {
    "branching_strategy": "none",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": null
  },
  "hooks": {
    "context_warnings": true
  }
}