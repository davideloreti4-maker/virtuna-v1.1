{
  "model_profile": "balanced",
  "model_profile_overrides": {
    "claude": { "haiku": "claude-sonnet-4-6" }
  },
  "model_overrides": {
    "gsd-planner": "claude-opus-4-8",
    "gsd-plan-checker": "claude-opus-4-8",
    "gsd-roadmapper": "claude-opus-4-8",
    "gsd-phase-researcher": "claude-opus-4-8",
    "gsd-project-researcher": "claude-opus-4-8",
    "gsd-research-synthesizer": "claude-opus-4-8",
    "gsd-advisor-researcher": "claude-opus-4-8",
    "gsd-assumptions-analyzer": "claude-opus-4-8",
    "gsd-verifier": "claude-opus-4-8",
    "gsd-code-reviewer": "claude-opus-4-8",
    "gsd-ui-researcher": "claude-opus-4-8",
    "gsd-executor": "claude-sonnet-4-6",
    "gsd-debugger": "claude-sonnet-4-6",
    "gsd-code-fixer": "claude-sonnet-4-6",
    "gsd-codebase-mapper": "claude-sonnet-4-6",
    "gsd-pattern-mapper": "claude-sonnet-4-6",
    "gsd-integration-checker": "claude-sonnet-4-6",
    "gsd-ui-checker": "claude-sonnet-4-6",
    "gsd-ui-auditor": "claude-sonnet-4-6",
    "gsd-doc-writer": "claude-sonnet-4-6",
    "gsd-doc-verifier": "claude-sonnet-4-6",
    "gsd-doc-classifier": "claude-sonnet-4-6",
    "gsd-doc-synthesizer": "claude-sonnet-4-6",
    "gsd-intel-updater": "claude-sonnet-4-6",
    "gsd-debug-session-manager": "claude-sonnet-4-6",
    "gsd-user-profiler": "claude-sonnet-4-6"
  },
  "models": {
    "planning": "opus",
    "discuss": "opus",
    "research": "opus",
    "execution": "sonnet",
    "verification": "opus",
    "completion": "sonnet"
  },
  "effort": {
    "default": "high",
    "routing_tier_defaults": { "light": "high", "standard": "high", "heavy": "high" }
  },
  "mode": "interactive",
  "parallelization": true,
  "granularity": "standard",
  "project": {
    "name": "virtuna-v1.1",
    "type": "greenfield",
    "framework": "nextjs",
    "version": "1.1.0"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "code_review": true,
    "code_review_depth": "standard",
    "ui_phase": true,
    "ui_safety_gate": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "nyquist_validation": false,
    "ai_integration_phase": false,
    "pattern_mapper": false,
    "post_planning_gaps": false,
    "context_coverage_gate": false,
    "security_enforcement": false,
    "discuss_mode": "discuss",
    "research_before_questions": true,
    "skip_discuss": false,
    "human_verify_mode": "end-of-phase",
    "auto_advance": false,
    "text_mode": false,
    "use_worktrees": false,
    "_auto_chain_active": false
  },
  "git": {
    "branching_strategy": "none",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": null
  },
  "hooks": {
    "context_warnings": true,
    "workflow_guard": false
  }
}
